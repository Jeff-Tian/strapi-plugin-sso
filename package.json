{
  "name": "@jeff-tian/strapi-plugin-sso",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "Plug-in for single sign-on with Strapi!",
  "strapi": {
    "displayName": "Single Sign On",
    "name": "strapi-plugin-sso",
    "description": "Version 5 enables single sign-on",
    "kind": "plugin"
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test": "jest",
    "lint": "eslint"
  },
  "keywords": [
    "strapi",
    "plugin",
    "oauth",
    "SSO",
    "Google",
    "Cognito"
  ],
  "peerDependencies": {
    "@strapi/strapi": "^5.24.1"
  },
  "dependencies": {
    "@strapi/design-system": "^2.0.0-rc.11",
    "@strapi/icons": "^2.0.0-rc.11",
    "@strapi/utils": "^5.24.1",
    "axios": "^1.8.4",
    "generate-password": "^1.7.1",
    "pkce-challenge": "^3.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "author": {
    "name": "Jeff Tian (https://jefftian.dev)",
    "url": "https://github.com/Jeff-Tian/strapi-plugin-sso"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jeff-Tian/strapi-plugin-sso"
  },
  "bugs": {
    "url": "https://github.com/Jeff-Tian/strapi-plugin-sso/issues"
  },
  "maintainers": [
    {
      "name": "Jeff-Tian"
    }
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.6.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@strapi/sdk-plugin": "^5.2.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.0.0",
    "globals": "^15.9.0",
    "jest": "^29.3.1"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".tmp",
      "dist",
      ".cache"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": ["babel-jest", { "presets": ["@babel/preset-env"] }]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.js",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/index.js",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
